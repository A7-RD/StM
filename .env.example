# Sanity (required for the site and /studio)
# https://www.sanity.io/manage → your project → Project ID & dataset name
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Optional (defaults to 2026-03-02 in src/sanity/env.js)
# NEXT_PUBLIC_SANITY_API_VERSION=2026-03-02

# Google Sheets — optional if you use CSV files in data/menus/ instead (see docs/google-sheets-setup.md)
# GOOGLE_SPREADSHEET_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
